<Window x:Class="GiglingBroadcastDeck.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Gigling Broadcast Deck"
        MinHeight="760"
        MinWidth="1180"
        Height="860"
        Width="1360"
        Background="#070B10"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        Foreground="#F4F7FB">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#070B10" />
        <SolidColorBrush x:Key="PanelBrush" Color="#111B27" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#172638" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#0B121B" />
        <SolidColorBrush x:Key="EdgeBrush" Color="#2C4862" />
        <SolidColorBrush x:Key="TextBrush" Color="#F4F8FC" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9DB5CA" />
        <SolidColorBrush x:Key="AccentBrush" Color="#7EE7B5" />
        <SolidColorBrush x:Key="GoldBrush" Color="#FFC76E" />
        <SolidColorBrush x:Key="ButtonBrush" Color="#1E3A55" />
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#2B557A" />
        <SolidColorBrush x:Key="ButtonDisabledBrush" Color="#223041" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="MutedText" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Background" Value="{StaticResource ButtonBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource EdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ButtonHoverBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource ButtonDisabledBrush}" />
                    <Setter Property="Foreground" Value="#65798D" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="#D7E2EF" />
            <Setter Property="BorderBrush" Value="{StaticResource EdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,4,0,10" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource EdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinHeight" Value="32" />
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PanelAltBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ButtonHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#65798D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource EdgeBrush}" />
            <Setter Property="Padding" Value="6" />
        </Style>
        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A2A3B" Offset="0" />
                        <GradientStop Color="#101923" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="{StaticResource EdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#0E1823" />
            <Setter Property="BorderBrush" Value="#223B54" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.Background>
            <RadialGradientBrush Center="0.18,0" GradientOrigin="0.18,0" RadiusX="1.1" RadiusY="1.2">
                <GradientStop Color="#132338" Offset="0" />
                <GradientStop Color="#070B10" Offset="0.56" />
                <GradientStop Color="#05070B" Offset="1" />
            </RadialGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelBorder}" Margin="0,0,0,14">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Command="{Binding RefreshRacesCommand}" Content="Refresh Races" Margin="12,0,0,0" />
                    <Button Command="{Binding HideOverlayCommand}" Content="Hide Overlay" Margin="12,0,0,0" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="READ-ONLY BROADCAST CONSOLE" Foreground="{StaticResource AccentBrush}" FontSize="12" FontWeight="Bold" />
                    <TextBlock Text="Gigling Broadcast Deck" FontSize="28" FontWeight="Bold" />
                    <TextBlock Text="{Binding OverlayServerStatus}" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                    <TextBlock Text="{Binding OverlayUrl, StringFormat=OBS Browser Source: {0}}" Style="{StaticResource MutedText}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <TabControl Grid.Row="1" Background="Transparent" BorderBrush="{StaticResource EdgeBrush}">
            <TabItem Header="Operator">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="400" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PanelBorder}" Margin="0,0,12,12">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Recent Races" Style="{StaticResource SectionTitle}" />
                            <ListBox ItemsSource="{Binding Races}" SelectedItem="{Binding SelectedRace, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="11" Margin="0,0,0,8" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1" CornerRadius="8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding RaceId, StringFormat=Race #{0}}" FontWeight="Bold" FontSize="15" />
                                                <TextBlock Text="{Binding Phase}" Foreground="{StaticResource AccentBrush}" />
                                                <TextBlock Text="{Binding EntrantCount, StringFormat=Entrants: {0}}" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding EntryFee, StringFormat=Entry: {0:0.####} ETH, TargetNullValue=Entry: ?}" Style="{StaticResource MutedText}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="0,0,12,12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Race Intelligence" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="{Binding SelectedRaceDetail.RaceId, StringFormat=Race #{0}}" FontSize="28" FontWeight="Bold" Margin="0,12,0,0" />
                                <TextBlock Text="{Binding SelectedRaceDetail.Phase, StringFormat=Phase: {0}}" Foreground="{StaticResource AccentBrush}" FontSize="18" FontWeight="SemiBold" />

                                <UniformGrid Columns="3" Margin="0,18,0,12">
                                    <Border Style="{StaticResource StatCard}">
                                        <StackPanel>
                                            <TextBlock Text="Entrants" Style="{StaticResource MutedText}" />
                                            <TextBlock Text="{Binding SelectedRaceDetail.EntrantCount, TargetNullValue=?}" FontSize="22" FontWeight="Bold" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatCard}">
                                        <StackPanel>
                                            <TextBlock Text="Field" Style="{StaticResource MutedText}" />
                                            <TextBlock Text="{Binding SelectedRaceDetail.MaxEntrants, TargetNullValue=?}" FontSize="22" FontWeight="Bold" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatCard}">
                                        <StackPanel>
                                            <TextBlock Text="Prize Pool" Style="{StaticResource MutedText}" />
                                            <TextBlock Text="{Binding SelectedRaceDetail.Pool, StringFormat={}{0:0.####} ETH, TargetNullValue=?}" FontSize="22" FontWeight="Bold" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatCard}" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="Track" Style="{StaticResource MutedText}" />
                                            <TextBlock Text="{Binding SelectedRaceDetail.TrackLength, StringFormat={}{0}m, TargetNullValue=?}" FontSize="22" FontWeight="Bold" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatCard}">
                                        <StackPanel>
                                            <TextBlock Text="Entry Fee" Style="{StaticResource MutedText}" />
                                            <TextBlock Text="{Binding SelectedRaceDetail.EntryFee, StringFormat={}{0:0.####} ETH, TargetNullValue=?}" FontSize="22" FontWeight="Bold" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatCard}">
                                        <StackPanel>
                                            <TextBlock Text="Race Type" Style="{StaticResource MutedText}" />
                                            <TextBlock Text="{Binding SelectedRaceDetail.RaceType, TargetNullValue=?}" FontSize="22" FontWeight="Bold" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <UniformGrid Columns="3" Margin="0,0,0,12">
                                    <TextBlock Text="{Binding SelectedRaceDetail.RaceType, StringFormat=Type: {0}, TargetNullValue=Type: ?}" Style="{StaticResource MutedText}" />
                                    <TextBlock Text="{Binding SelectedRaceDetail.Weather, StringFormat=Weather: {0}, TargetNullValue=Weather: ?}" Style="{StaticResource MutedText}" />
                                    <TextBlock Text="{Binding SelectedRaceDetail.Source, StringFormat=Source: {0}, TargetNullValue=Source: public API}" Style="{StaticResource MutedText}" />
                                </UniformGrid>

                                <TextBlock Text="Lifecycle" FontWeight="Bold" Margin="0,8,0,4" />
                                <TextBlock Text="{Binding PhaseDescription}" Foreground="#BDD2E5" />

                                <TextBlock Text="Projected Payouts" FontWeight="Bold" Margin="0,16,0,4" />
                                <ItemsControl ItemsSource="{Binding SelectedRaceDetail.ProjectedPayouts}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0F1822" CornerRadius="6" Padding="8" Margin="0,0,8,8">
                                                <TextBlock Text="{Binding StringFormat={}{0:0.####} ETH}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Player &amp; Gigling Details" FontWeight="Bold" Margin="0,16,0,4" />
                                <ItemsControl ItemsSource="{Binding SelectedRaceDetail.ResultEntrants}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0F1822" BorderBrush="#223B54" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName, StringFormat=Gigling {0}}" FontWeight="Bold" />
                                                    <WrapPanel Margin="0,4,0,0">
                                                        <TextBlock Text="{Binding OwnerName, StringFormat=Owner: {0}, TargetNullValue=Owner: ?}" Style="{StaticResource MutedText}" Margin="0,0,14,0" />
                                                        <TextBlock Text="{Binding OwnerAddress, StringFormat=Wallet: {0}, TargetNullValue=Wallet: ?}" Style="{StaticResource MutedText}" Margin="0,0,14,0" />
                                                        <TextBlock Text="{Binding Slot, StringFormat=Slot: {0}, TargetNullValue=Slot: ?}" Style="{StaticResource MutedText}" Margin="0,0,14,0" />
                                                        <TextBlock Text="{Binding FinishTimeMs, StringFormat=Finish: {0} ms, TargetNullValue=Finish: ?}" Style="{StaticResource MutedText}" Margin="0,0,14,0" />
                                                        <TextBlock Text="{Binding IsJuiced, StringFormat=Juiced: {0}, TargetNullValue=Juiced: ?}" Style="{StaticResource MutedText}" />
                                                    </WrapPanel>
                                                    <WrapPanel Margin="0,4,0,0">
                                                        <TextBlock Text="{Binding PetRarity, StringFormat=Rarity: {0}, TargetNullValue=Rarity: ?}" Style="{StaticResource MutedText}" Margin="0,0,14,0" />
                                                        <TextBlock Text="{Binding PetGender, StringFormat=Gender: {0}, TargetNullValue=Gender: ?}" Style="{StaticResource MutedText}" Margin="0,0,14,0" />
                                                        <TextBlock Text="{Binding PetElo, StringFormat=ELO: {0:0}, TargetNullValue=ELO: ?}" Style="{StaticResource MutedText}" Margin="0,0,14,0" />
                                                        <TextBlock Text="{Binding OwnerPetCount, StringFormat=Stable: {0} pets, TargetNullValue=Stable: ?}" Style="{StaticResource MutedText}" />
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Overlay Controls" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="Preset" Style="{StaticResource MutedText}" />
                                <ComboBox ItemsSource="{Binding OverlayPresets}" SelectedItem="{Binding SelectedOverlayPreset}" />
                                <TextBlock Text="Position" Style="{StaticResource MutedText}" />
                                <ComboBox ItemsSource="{Binding OverlayPositions}" SelectedItem="{Binding SelectedOverlayPosition}" />

                                <Button Command="{Binding ShowRaceCardCommand}" Content="Show Race Card" />
                                <Button Command="{Binding ShowResultCardCommand}" Content="Show Result Card" />
                                <Button Command="{Binding ShowPositionsCommand}"
                                        Content="Show Positions"
                                        IsEnabled="False"
                                        ToolTip="Temporarily disabled while live position rendering is refined." />
                                <Button Command="{Binding ShowTickerCommand}" Content="Show Ticker" />
                                <Button Command="{Binding HideOverlayCommand}" Content="Hide Overlay" />
                                <Button Command="{Binding CopyDiscordSummaryCommand}" Content="Copy Discord Summary" />

                                <TextBlock Text="Broadcast Rundown" FontSize="18" FontWeight="Bold" Margin="0,16,0,8" />
                                <TextBox Text="{Binding NewRundownText, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Command="{Binding AddRundownLineCommand}" Content="Pin Ticker Line" />
                                <Button Command="{Binding AddSelectedRaceToRundownCommand}" Content="Pin Selected Race" />
                                <Button Command="{Binding ClearRundownCommand}" Content="Clear Rundown" />
                                <ListBox ItemsSource="{Binding RundownItems}"
                                         MinHeight="110"
                                         MouseDoubleClick="RundownItems_MouseDoubleClick" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Row="1" Grid.ColumnSpan="3" Style="{StaticResource PanelBorder}">
                        <Expander Header="Raw Source JSON"
                                  IsExpanded="False"
                                  Foreground="{StaticResource TextBrush}">
                            <TextBox Text="{Binding RawJson, Mode=OneWay}"
                                     FontFamily="Consolas"
                                     FontSize="11"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="NoWrap"
                                     MinHeight="140"
                                     MaxHeight="180"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto" />
                        </Expander>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>

        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,14,0,0">
            <DockPanel>
                <ItemsControl DockPanel.Dock="Right" ItemsSource="{Binding StatusChips}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1B2B3C" CornerRadius="6" Padding="8,4" Margin="8,0,0,0">
                                <TextBlock Text="{Binding}" Foreground="#BDD2E5" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="{Binding StatusText}" Foreground="#D7E2EF" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
