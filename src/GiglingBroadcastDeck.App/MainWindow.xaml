<Window x:Class="GiglingBroadcastDeck.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Gigling Broadcast Deck"
        MinHeight="760"
        MinWidth="1180"
        Height="820"
        Width="1280"
        Background="#10151C"
        Foreground="#F4F7FB">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F4F7FB" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Background" Value="#27425F" />
            <Setter Property="Foreground" Value="#F4F7FB" />
            <Setter Property="BorderBrush" Value="#3B668E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0B1016" />
            <Setter Property="Foreground" Value="#D7E2EF" />
            <Setter Property="BorderBrush" Value="#2B3E52" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#121C27" />
            <Setter Property="Foreground" Value="#F4F7FB" />
            <Setter Property="BorderBrush" Value="#2B3E52" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="220" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#162232" CornerRadius="16" Padding="18" Margin="0,0,0,16">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Command="{Binding RefreshRacesCommand}" Content="Refresh Races" Margin="12,0,0,0" />
                    <Button Command="{Binding HideOverlayCommand}" Content="Hide Overlay" Margin="12,0,0,0" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Gigling Broadcast Deck" FontSize="28" FontWeight="Bold" />
                    <TextBlock Text="{Binding OverlayServerStatus}" Foreground="#9DB6CF" Margin="0,4,0,0" />
                    <TextBlock Text="{Binding OverlayUrl, StringFormat=OBS Browser Source: {0}}" Foreground="#9DB6CF" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#162232" CornerRadius="14" Padding="14" Margin="0,0,14,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Recent Races" FontSize="20" FontWeight="Bold" Margin="0,0,0,12" />
                    <ListBox ItemsSource="{Binding Races}" SelectedItem="{Binding SelectedRace, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" Margin="0,0,0,8" Background="#1B2B3C" CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding RaceId, StringFormat=Race #{0}}" FontWeight="Bold" FontSize="15" />
                                        <TextBlock Text="{Binding Phase}" Foreground="#80D6A9" />
                                        <TextBlock Text="{Binding EntrantCount, StringFormat=Entrants: {0}}" Foreground="#AFC2D5" />
                                        <TextBlock Text="{Binding LastFetchedAt, StringFormat=Fetched: {0:HH:mm:ss}}" Foreground="#7890A6" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="#162232" CornerRadius="14" Padding="18" Margin="0,0,14,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Selected Race" FontSize="20" FontWeight="Bold" />
                        <TextBlock Text="{Binding SelectedRaceDetail.RaceId, StringFormat=Race #{0}}" FontSize="26" FontWeight="Bold" Margin="0,12,0,0" />
                        <TextBlock Text="{Binding SelectedRaceDetail.Phase, StringFormat=Phase: {0}}" Foreground="#80D6A9" FontSize="18" />
                    </StackPanel>

                    <UniformGrid Grid.Row="1" Columns="3" Margin="0,18,0,18">
                        <Border Background="#0F1822" CornerRadius="12" Padding="12" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Entrants" Foreground="#8EA8C2" />
                                <TextBlock Text="{Binding SelectedRaceDetail.EntrantCount, TargetNullValue=?}" FontSize="26" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                        <Border Background="#0F1822" CornerRadius="12" Padding="12" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Max Field" Foreground="#8EA8C2" />
                                <TextBlock Text="{Binding SelectedRaceDetail.MaxEntrants, TargetNullValue=?}" FontSize="26" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                        <Border Background="#0F1822" CornerRadius="12" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Pool" Foreground="#8EA8C2" />
                                <TextBlock Text="{Binding SelectedRaceDetail.Pool, StringFormat={}{0:0.####} ETH, TargetNullValue=Unknown}" FontSize="26" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Grid.Row="2" Background="#0F1822" CornerRadius="12" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Lifecycle Explanation" FontWeight="Bold" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding PhaseDescription}" Foreground="#BDD2E5" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="#162232" CornerRadius="14" Padding="18">
                <StackPanel>
                    <TextBlock Text="Overlay Controls" FontSize="20" FontWeight="Bold" Margin="0,0,0,16" />
                    <Button Command="{Binding ShowRaceCardCommand}" Content="Show Race Card" />
                    <Button Command="{Binding ShowResultCardCommand}" Content="Show Result Card" />
                    <Button Command="{Binding ShowTickerCommand}" Content="Show Ticker" />
                    <Button Command="{Binding HideOverlayCommand}" Content="Hide Overlay" />
                    <Button Command="{Binding CopyDiscordSummaryCommand}" Content="Copy Discord Summary" Margin="0,14,0,10" />

                    <Border Background="#0F1822" CornerRadius="12" Padding="12" Margin="0,14,0,0">
                        <StackPanel>
                            <TextBlock Text="Local Diagnostics" FontWeight="Bold" Margin="0,0,0,6" />
                            <TextBlock Text="{Binding HealthUrl, StringFormat=Health: {0}}" Foreground="#9DB6CF" />
                            <TextBlock Text="{Binding IsOverlayServerRunning, StringFormat=Server running: {0}}" Foreground="#9DB6CF" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#162232" CornerRadius="14" Padding="14" Margin="0,16,0,12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Raw Source JSON" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                <TextBox Text="{Binding RawJson}" FontFamily="Consolas" FontSize="12" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
            </DockPanel>
        </Border>

        <Border Grid.Row="3" Background="#0B1016" BorderBrush="#2B3E52" BorderThickness="1" CornerRadius="10" Padding="12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding IsStale, StringFormat=Stale: {0}}" Foreground="#FFCA7A" Margin="18,0,0,0" />
                <TextBlock DockPanel.Dock="Right" Text="{Binding HasError, StringFormat=Error: {0}}" Foreground="#FF8B8B" Margin="18,0,0,0" />
                <TextBlock Text="{Binding StatusText}" Foreground="#D7E2EF" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
